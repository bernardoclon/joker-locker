<div id="chemical-balance-lock">
    <h1>{{general.label}}</h1>
    {{#if general.description}}<p class="notes">{{{general.description}}}</p>{{/if}}
    <p class="notes">{{localize "joker-locker.chemical-balance-lock.playerInfo"}}</p>

    <div class="chemical-lab">
        <div class="tubes-rack">
            {{#each baseColors}}
            <div class="tube-station">
                <div class="test-tube">
                    <div class="liquid" style="background-color: {{this.color}}; height: {{this.height}}%;"></div>
                    <div class="glass-shine"></div>
                    <div class="measure-marks"></div>
                </div>
                <div class="controls">
                    <button type="button" class="subtract-color" data-index="{{@index}}"><i class="fas fa-minus"></i></button>
                    <span class="amount-display">{{this.amount}}</span>
                    <button type="button" class="add-color" data-index="{{@index}}"><i class="fas fa-plus"></i></button>
                </div>
            </div>
            {{/each}}
        </div>

        <div class="mixing-station">
            <div class="beaker">
                <div class="liquid mixed-liquid" style="background-color: {{mixedColor}}; height: 60%;"></div>
                <div class="glass-shine"></div>
            </div>
            <label>{{localize "joker-locker.chemical-balance-lock.mixedColor"}}</label>
        </div>
    </div>
</div>