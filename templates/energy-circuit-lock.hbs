<div id="energy-circuit-lock">
    <h1>{{general.label}}</h1>
    {{#if general.description}}<p class="notes">{{{general.description}}}</p>{{/if}}
    
    <div class="circuit-container">
        {{#if gameOver}}
        <div class="game-over-container">
            <h2>{{localize "joker-locker.notifications.failedAttempt"}}</h2>
        </div>
        {{else}}
        <div class="timer-display" id="circuit-timer">
            {{localize "joker-locker.energy-circuit-lock.timer"}}: <span>{{timeLeft}}</span>s
        </div>
        {{/if}}

        <div class="circuit-grid" style="grid-template-columns: repeat({{gridSize}}, 1fr); grid-template-rows: repeat({{gridSize}}, 1fr);">
            {{#each grid}}
            <div class="node {{type}} {{#if powered}}powered{{/if}}" 
                 data-index="{{@index}}" 
                 data-row="{{row}}" 
                 data-col="{{col}}">
                <svg viewBox="0 0 100 100" style="transform: rotate({{rotation}}deg);">
                    {{#if (eq type "straight")}}
                        <line x1="50" y1="0" x2="50" y2="100" />
                    {{/if}}
                    {{#if (eq type "corner")}}
                        <path d="M50,0 L50,50 L100,50" />
                    {{/if}}
                    {{#if (eq type "tshape")}}
                        <path d="M50,0 L50,100 M50,50 L100,50" />
                    {{/if}}
                    {{#if (eq type "cross")}}
                        <path d="M50,0 L50,100 M0,50 L100,50" />
                    {{/if}}
                    {{#if (eq type "source")}}
                        <rect x="25" y="25" width="50" height="50" fill="currentColor" style="opacity: 0.3"/>
                        <circle cx="50" cy="50" r="15" fill="currentColor" />
                        <line x1="50" y1="50" x2="50" y2="100" /> <!-- Output South by default -->
                    {{/if}}
                    {{#if (eq type "sink")}}
                        <rect x="25" y="25" width="50" height="50" fill="currentColor" style="opacity: 0.3"/>
                        <rect x="35" y="35" width="30" height="30" fill="currentColor" />
                        <line x1="50" y1="0" x2="50" y2="50" /> <!-- Input North by default -->
                    {{/if}}
                </svg>
            </div>
            {{/each}}
        </div>
        {{#if gameOver}}
        <div class="game-over-controls" style="text-align: center;">
            <button class="restart-puzzle"><i class="fas fa-redo"></i> {{localize "joker-locker.mastermind-lock.reset"}}</button>
        </div>
        {{/if}}
        {{#if isSolved}}
        <div class="solved-container" style="text-align: center;">
            <button class="restart-puzzle"><i class="fas fa-redo"></i> {{localize "joker-locker.mastermind-lock.reset"}}</button>
        </div>
        {{/if}}
    </div>
</div>